        dtype_check_status%numTotal = dtype_check_status%numTotal + 1 
        IF (ALL(var%alpha == kgenref_var%alpha)) THEN 
            dtype_check_status%numIdentical = dtype_check_status%numIdentical + 1 
            IF (kgen_verboseLevel > 2) THEN 
                IF (check_status%rank == 0) THEN 
                    WRITE (*, *) trim(adjustl(varname)), "%alpha is IDENTICAL." 
                END IF   
            END IF   
            check_result = CHECK_IDENTICAL 
        ELSE 
            ALLOCATE (buf1_alpha(SIZE(var%alpha,dim=1))) 
            ALLOCATE (buf2_alpha(SIZE(var%alpha,dim=1))) 
            n_alpha = COUNT(var%alpha /= kgenref_var%alpha) 
            WHERE ( ABS(kgenref_var%alpha) > kgen_minvalue ) 
                buf1_alpha = ((var%alpha-kgenref_var%alpha)/kgenref_var%alpha)**2 
                buf2_alpha = (var%alpha-kgenref_var%alpha)**2 
            ELSEWHERE 
                buf1_alpha = (var%alpha-kgenref_var%alpha)**2 
                buf2_alpha = buf1_alpha 
            END WHERE   
            nrmsdiff_alpha = SQRT(SUM(buf1_alpha)/REAL(n_alpha)) 
            rmsdiff_alpha = SQRT(SUM(buf2_alpha)/REAL(n_alpha)) 
            IF (rmsdiff_alpha > kgen_tolerance) THEN 
                dtype_check_status%numOutTol = dtype_check_status%numOutTol + 1 
                IF (kgen_verboseLevel > 1) THEN 
                    IF (check_status%rank == 0) THEN 
