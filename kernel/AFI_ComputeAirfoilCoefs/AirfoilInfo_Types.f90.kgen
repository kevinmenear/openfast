!verify state subroutine for kv_airfoilinfo_types_afi_table_type 
RECURSIVE SUBROUTINE kv_airfoilinfo_types_afi_table_type(varname, check_status, var, kgenref_var) 
    CHARACTER(LEN=*), INTENT(IN) :: varname 
    TYPE(check_t), INTENT(INOUT) :: check_status 
    TYPE(afi_table_type), INTENT(IN) :: var, kgenref_var 
    TYPE(check_t) :: dtype_check_status, comp_check_status 
    INTEGER :: check_result 
    LOGICAL :: is_print = .FALSE. 
      
    INTEGER :: n_alpha 
    real(KIND=reki) :: nrmsdiff_alpha, rmsdiff_alpha 
    real(KIND=reki), ALLOCATABLE :: buf1_alpha(:), buf2_alpha(:) 
    INTEGER :: n_coefs 
    real(KIND=reki) :: nrmsdiff_coefs, rmsdiff_coefs 
    real(KIND=reki), ALLOCATABLE :: buf1_coefs(:,:), buf2_coefs(:,:) 
    INTEGER :: n_splinecoefs 
    real(KIND=reki) :: nrmsdiff_splinecoefs, rmsdiff_splinecoefs 
    real(KIND=reki), ALLOCATABLE :: buf1_splinecoefs(:,:,:), buf2_splinecoefs(:,:,:) 
    real(KIND=reki) :: diff_userprop 
    real(KIND=reki) :: diff_re 
    integer(KIND=intki) :: diff_numalf 
      
    check_status%numTotal = check_status%numTotal + 1 
      
    CALL kgen_init_check(dtype_check_status, rank=check_status%rank) 
