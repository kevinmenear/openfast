        CALL kgen_init_check(comp_check_status, rank=check_status%rank) 
        DO   idx1_table = LBOUND(var%table,1), UBOUND(var%table,1) 
            CALL kv_airfoilinfo_types_afi_table_type(trim(adjustl(varname))//"%table", comp_check_status, var%table(idx1_table), &
