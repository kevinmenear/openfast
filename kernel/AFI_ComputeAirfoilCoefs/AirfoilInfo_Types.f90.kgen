!verify state subroutine for kv_airfoilinfo_types_afi_ua_bl_type 
RECURSIVE SUBROUTINE kv_airfoilinfo_types_afi_ua_bl_type(varname, check_status, var, kgenref_var) 
    CHARACTER(LEN=*), INTENT(IN) :: varname 
    TYPE(check_t), INTENT(INOUT) :: check_status 
    TYPE(afi_ua_bl_type), INTENT(IN) :: var, kgenref_var 
    TYPE(check_t) :: dtype_check_status, comp_check_status 
    INTEGER :: check_result 
    LOGICAL :: is_print = .FALSE. 
      
    real(KIND=reki) :: diff_alpha0 
    real(KIND=reki) :: diff_alpha1 
    real(KIND=reki) :: diff_alpha2 
    real(KIND=reki) :: diff_eta_e 
    real(KIND=reki) :: diff_c_nalpha 
    real(KIND=reki) :: diff_c_lalpha 
    real(KIND=reki) :: diff_t_f0 
    real(KIND=reki) :: diff_t_v0 
    real(KIND=reki) :: diff_t_p 
    real(KIND=reki) :: diff_t_vl 
    real(KIND=reki) :: diff_b1 
    real(KIND=reki) :: diff_b2 
    real(KIND=reki) :: diff_b5 
    real(KIND=reki) :: diff_a1 
    real(KIND=reki) :: diff_a2 
    real(KIND=reki) :: diff_a5 
    real(KIND=reki) :: diff_s1 
    real(KIND=reki) :: diff_s2 
    real(KIND=reki) :: diff_s3 
    real(KIND=reki) :: diff_s4 
    real(KIND=reki) :: diff_cn1 
    real(KIND=reki) :: diff_cn2 
    real(KIND=reki) :: diff_st_sh 
    real(KIND=reki) :: diff_cd0 
    real(KIND=reki) :: diff_cm0 
    real(KIND=reki) :: diff_k0 
    real(KIND=reki) :: diff_k1 
    real(KIND=reki) :: diff_k2 
    real(KIND=reki) :: diff_k3 
    real(KIND=reki) :: diff_k1_hat 
    real(KIND=reki) :: diff_x_cp_bar 
    real(KIND=reki) :: diff_uacutout 
    real(KIND=reki) :: diff_uacutout_delta 
    real(KIND=reki) :: diff_uacutout_blend 
    real(KIND=reki) :: diff_filtcutoff 
    real(KIND=reki) :: diff_alphaupper 
    real(KIND=reki) :: diff_alphalower 
    real(KIND=reki) :: diff_c_alphalower 
    real(KIND=reki) :: diff_c_alphaupper 
    real(KIND=reki) :: diff_alpha0reverseflow 
    real(KIND=reki) :: diff_alphabreakupper 
    real(KIND=reki) :: diff_cnbreakupper 
    real(KIND=reki) :: diff_alphabreaklower 
    real(KIND=reki) :: diff_cnbreaklower 
      
    check_status%numTotal = check_status%numTotal + 1 
      
    CALL kgen_init_check(dtype_check_status, rank=check_status%rank) 
    dtype_check_status%numTotal = dtype_check_status%numTotal + 1 
    IF (var%alpha0 == kgenref_var%alpha0) THEN 
        dtype_check_status%numIdentical = dtype_check_status%numIdentical + 1 
        IF (kgen_verboseLevel > 2) THEN 
            IF (check_status%rank == 0) THEN 
                WRITE (*, *) trim(adjustl(varname)), "%alpha0 is IDENTICAL." 
            END IF   
        END IF   
        check_result = CHECK_IDENTICAL 
    ELSE 
        diff_alpha0 = ABS(var%alpha0 - kgenref_var%alpha0) 
        IF (diff_alpha0 <= kgen_tolerance) THEN 
            dtype_check_status%numInTol = dtype_check_status%numInTol + 1 
            IF (kgen_verboseLevel > 1) THEN 
                IF (check_status%rank == 0) THEN 
                    WRITE (*, *) trim(adjustl(varname)), "%alpha0 is NOT IDENTICAL(within tolerance)." 
                END IF   
            END IF   
            check_result = CHECK_IN_TOL 
        ELSE 
            dtype_check_status%numOutTol = dtype_check_status%numOutTol + 1 
            IF (kgen_verboseLevel > 1) THEN 
                IF (check_status%rank == 0) THEN 
                    WRITE (*, *) trim(adjustl(varname)), "%alpha0 is NOT IDENTICAL(out of tolerance)." 
                END IF   
            END IF   
            check_result = CHECK_OUT_TOL 
        END IF   
    END IF   
    IF (check_result == CHECK_IDENTICAL) THEN 
